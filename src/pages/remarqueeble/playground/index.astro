---
import BaseLayout from '../../../components/BaseLayout.astro'
import { site } from '../../../data/site'
---

<BaseLayout title="Playground" description={site.description}>
	<main>
		<form class="playground" data-playground>
			<section class="playground-controls" aria-labelledby="controls-heading">
				<h2 id="controls-heading">Controls</h2>

				<div class="control-grid">
					<label>
						<span>Show</span>
						<select name="show">
							<option value="re-marquee">re-marquee</option>
							<option value="marquee">marquee</option>
							<option value="both">both</option>
						</select>
					</label>

					<label>
						<span>Behavior</span>
						<select name="behavior">
							<option value="scroll">scroll</option>
							<option value="alternate">alternate</option>
							<option value="slide">slide</option>
						</select>
					</label>

					<label>
						<span>Direction</span>
						<select name="direction">
							<option value="left">left</option>
							<option value="right">right</option>
							<option value="up">up</option>
							<option value="down">down</option>
						</select>
					</label>

					<label>
						<span>Loop</span>
						<input
							name="loop"
							type="number"
							min="-1"
							step="1"
							placeholder="-1"
						/>
					</label>

					<label>
						<span>Scrollamount</span>
						<input
							name="scrollamount"
							type="range"
							min="0"
							max="30"
							step="1"
							value="6"
						/>
						<output data-output="scrollamount">6</output>
					</label>

					<label>
						<span>Scrolldelay</span>
						<input
							name="scrolldelay"
							type="range"
							min="0"
							max="500"
							step="5"
							value="85"
						/>
						<output data-output="scrolldelay">85</output>
					</label>

					<label>
						<span>Width</span>
						<input name="width" type="text" value="100%" />
					</label>

					<label>
						<span>Height</span>
						<input name="height" type="text" value="" placeholder="auto" />
					</label>

					<label>
						<span>Bgcolor</span>
						<input
							name="bgcolor"
							type="text"
							value=""
							placeholder="transparent"
						/>
					</label>

					<label>
						<span>Hspace</span>
						<input name="hspace" type="text" value="" placeholder="0" />
					</label>

					<label>
						<span>Vspace</span>
						<input name="vspace" type="text" value="" placeholder="0" />
					</label>

					<label class="checkbox-control">
						<input name="truespeed" type="checkbox" />
						<span>truespeed</span>
					</label>
				</div>

				<label class="content-control">
					<span>Content</span>
					<textarea name="content" rows="4"></textarea>
				</label>
			</section>

			<section class="playground-preview" aria-labelledby="preview-heading">
				<h2 id="preview-heading">Display</h2>
				<div class="preview-stage" data-preview></div>
			</section>

			<section class="playground-code" aria-labelledby="code-heading">
				<div class="code-header">
					<h2 id="code-heading">Code</h2>
					<button type="button" data-copy>Copy</button>
				</div>
				<pre><code data-code /></pre>
			</section>
		</form>
	</main>

	<script slot="scripts">
		const form = document.querySelector('[data-playground]')
		const preview = document.querySelector('[data-preview]')
		const code = document.querySelector('[data-code]')
		const copyButton = document.querySelector('[data-copy]')
		const scrollAmountOutput = document.querySelector(
			'[data-output="scrollamount"]'
		)
		const scrollDelayOutput = document.querySelector(
			'[data-output="scrolldelay"]'
		)
		const defaultValues = {
			behavior: 'scroll',
			content:
				'Default marquee behaviour. Nisi nisi anim enim consequat pariatur reprehenderit.',
			direction: 'left',
			scrollamount: '6',
			scrolldelay: '85',
			width: '100%',
		}
		const textAttributes = [
			'behavior',
			'direction',
			'loop',
			'scrollamount',
			'scrolldelay',
			'width',
			'height',
			'bgcolor',
			'hspace',
			'vspace',
		]

		const escapeHtml = value =>
			value
				.replaceAll('&', '&amp;')
				.replaceAll('<', '&lt;')
				.replaceAll('>', '&gt;')

		const escapeAttribute = value => escapeHtml(value).replaceAll('"', '&quot;')

		const getValue = name => form?.elements.namedItem(name)?.value ?? ''

		const getAttributes = () => {
			const attributes = []

			for (const name of textAttributes) {
				const value = getValue(name).trim()
				if (!value) continue
				if (defaultValues[name] === value) continue
				attributes.push([name, value])
			}

			if (form?.elements.namedItem('truespeed')?.checked) {
				attributes.push(['truespeed', ''])
			}

			return attributes
		}

		const getCode = tagName => {
			const attributes = getAttributes()
				.map(([name, value]) =>
					value ? `${name}="${escapeAttribute(value)}"` : name
				)
				.join(' ')
			const openTag = attributes ? `<${tagName} ${attributes}>` : `<${tagName}>`
			const content = escapeHtml(getValue('content').trim())

			return `${openTag}${content}</${tagName}>`
		}

		const applyAttributes = element => {
			for (const [name, value] of getAttributes()) {
				if (value) {
					element.setAttribute(name, value)
				} else {
					element.setAttribute(name, '')
				}
			}
		}

		const createPreviewItem = tagName => {
			const wrapper = document.createElement('div')
			const label = document.createElement('h3')
			const marquee = document.createElement(tagName)

			wrapper.className = 'preview-item'
			label.textContent = `<${tagName}>`
			marquee.textContent = getValue('content')
			applyAttributes(marquee)
			wrapper.append(label, marquee)

			return wrapper
		}

		const render = () => {
			if (!form || !preview || !code) return

			const show = getValue('show')
			const tagNames =
				show === 'both' ? ['re-marquee', 'marquee'] : [show || 're-marquee']

			scrollAmountOutput.textContent = getValue('scrollamount')
			scrollDelayOutput.textContent = getValue('scrolldelay')
			preview.replaceChildren(
				...tagNames.map(tagName => createPreviewItem(tagName))
			)
			code.textContent = tagNames.map(tagName => getCode(tagName)).join('\n')
		}

		form?.addEventListener('input', render)
		form?.addEventListener('change', render)
		if (form) {
			form.elements.namedItem('content').value = defaultValues.content
		}
		copyButton?.addEventListener('click', async () => {
			if (!code?.textContent) return

			await navigator.clipboard.writeText(code.textContent)
			copyButton.textContent = 'Copied'
			setTimeout(() => {
				copyButton.textContent = 'Copy'
			}, 1200)
		})
		render()
	</script>
</BaseLayout>
