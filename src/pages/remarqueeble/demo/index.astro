---
import BaseLayout from '../../../components/BaseLayout.astro'
import { site } from '../../../data/site'
---

<BaseLayout title="Demo" description={site.description}>
	<main>
		<p>
			A tiny custom element tribute to the cursed glory of
			<code>&lt;marquee&gt;</code>, exposed as
			<code>&lt;re-marquee&gt;</code> and
			<code>&lt;re-marquee-ble&gt;</code>.
		</p>
		<p>
			Install it with <code>npm install remarqueeble</code>, then import
			<code>remarqueeble/auto</code> or call
			<code>defineRemarqueebleElements()</code> yourself.
		</p>

		<h2>Default</h2>
		<h3><code>&lt;re-marquee&gt;</code></h3>
		<re-marquee>
			Default marquee: left, scroll, scrollamount 6, scrolldelay 85. Nisi nisi
			anim enim consequat pariatur reprehenderit. Proident cillum incididunt in
			laborum est duis quis.
		</re-marquee>

		<h2>Directions</h2>
		<h3><code>direction="left"</code></h3>
		<re-marquee direction="left">← I crawl left into the neon ditch.</re-marquee
		>

		<h3><code>direction="right"</code></h3>
		<re-marquee direction="right">
			I flee right with suspicious confidence. →
		</re-marquee>

		<h3><code>direction="up"</code></h3>
		<div class="tall">
			<re-marquee direction="up">
				↑ Upward scroll. Ancient guestbook energy rising from the crypt.
			</re-marquee>
		</div>

		<h3><code>direction="down"</code></h3>
		<div class="tall">
			<re-marquee direction="down">
				Downward scroll. A banner descending from the GeoCities ceiling. ↓
			</re-marquee>
		</div>

		<h2>Scroll Speed</h2>
		<h3><code>scrollamount="1"</code></h3>
		<re-marquee scrollamount="1">
			Very slow. The dial-up modem is thinking.
		</re-marquee>

		<h3><code>scrollamount="12"</code></h3>
		<re-marquee scrollamount="12">
			Fast. Too fast. The web page has escaped containment.
		</re-marquee>

		<h3><code>scrolldelay="200"</code></h3>
		<re-marquee scrolldelay="200">
			Slow delay. Chunky little steps across the screen.
		</re-marquee>

		<h2>Behaviour</h2>
		<h3><code>behavior="scroll"</code></h3>
		<re-marquee behavior="scroll">
			Scroll behaviour loops from one side to the other.
		</re-marquee>

		<h3><code>behavior="alternate"</code></h3>
		<re-marquee behavior="alternate">
			I bounce between the walls like a screensaver DVD logo.
		</re-marquee>

		<h3><code>behavior="slide" loop="2"</code></h3>
		<re-marquee behavior="slide" loop="2">Slides twice.</re-marquee>

		<h2>CSS Mode</h2>
		<h3><code>mode="css"</code></h3>
		<re-marquee mode="css">
			CSS mode imitates the marquee look with a CSS animation.
		</re-marquee>

		<h3><code>mode="css" behavior="alternate"</code></h3>
		<re-marquee mode="css" behavior="alternate" scrollamount="4">
			CSS alternate mode bounces by animation, not requestAnimationFrame.
		</re-marquee>

		<h2>Presentation</h2>
		<h3><code>bgcolor="var(--dress-bg-2)" width="18rem"</code></h3>
		<re-marquee bgcolor="var(--dress-bg-2)" width="18rem">
			The background color and width come from marquee attributes.
		</re-marquee>

		<h3><code>hspace="2rem" vspace="1rem"</code></h3>
		<re-marquee hspace="2rem" vspace="1rem">
			Horizontal and vertical spacing map to margins.
		</re-marquee>

		<h3><code>height="6rem" direction="up"</code></h3>
		<div class="tall">
			<re-marquee height="6rem" direction="up">
				The explicit height overrides the vertical default of 200px.
			</re-marquee>
		</div>

		<h2>API</h2>
		<p>
			<button type="button" data-demo-action="start">Start</button>
			<button type="button" data-demo-action="stop">Stop</button>
		</p>

		<re-marquee id="api-demo" scrollamount="5">
			Controlled with start() and stop().
		</re-marquee>
	</main>

	<script slot="scripts">
		const apiDemo = document.querySelector('#api-demo')
		document
			.querySelector('[data-demo-action="start"]')
			?.addEventListener('click', () => apiDemo?.start())
		document
			.querySelector('[data-demo-action="stop"]')
			?.addEventListener('click', () => apiDemo?.stop())
	</script>
</BaseLayout>
