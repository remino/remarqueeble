---
import BaseLayout from '../../../components/BaseLayout.astro'
import { site } from '../../../data/site'
import '../../../assets/css/demo.css'
import demoScriptUrl from '../../../assets/js/demo.js?url'
---

<BaseLayout
	title="Demo"
	description={site.description}
	path="/remarqueeble/demo/"
	bodyClass="demo-page"
	showHeader={false}>
	<main class="playground-layout">
		<header class="playground-header">
			<hgroup>
				<h1>
					<a href="/remarqueeble/" aria-labelledby="site-title-readable">
						<span id="site-title-readable" class="sr-only">
							<mark>{site.readableTitle}</mark>
						</span>
						<mark aria-hidden="true">{site.title}</mark>
					</a>
				</h1>
				<h2>demo</h2>
			</hgroup>

			<nav aria-label="Demo navigation">
				<ul>
					<li><a role="button" href="/remarqueeble/">Back</a></li>
					<li><button type="button" data-reset>Reset</button></li>
					<li>
						<button type="button" data-fullscreen>Full Screen</button>
					</li>
				</ul>
			</nav>
		</header>

		<section
			id="playground-display"
			class="playground-display"
			aria-labelledby="display-heading">
			<h1 id="display-heading" class="sr-only">Demo</h1>
			<div class="preview-stage" data-preview></div>
			<div class="code-preview">
				<label>
					<span class="code-preview-header">
						<span><strong>Code</strong></span>
					</span>
					<textarea data-code readonly rows="6" spellcheck="false"></textarea>
					<button type="button" data-copy>Copy</button>
				</label>
			</div>
		</section>

		<section class="playground-controls" aria-label="Demo controls">
			<form data-playground>
				<details open>
					<summary>Playback</summary>

					<label>
						<span>Show</span>
						<select name="show">
							<option value="re-marquee">re-marquee</option>
							<option value="marquee">marquee</option>
							<option value="both">both</option>
						</select>
					</label>

					<label>
						<span>Behavior</span>
						<select name="behavior">
							<option value="scroll">scroll</option>
							<option value="alternate">alternate</option>
							<option value="slide">slide</option>
						</select>
					</label>

					<label>
						<span>Direction</span>
						<select name="direction">
							<option value="left">left</option>
							<option value="right">right</option>
							<option value="up">up</option>
							<option value="down">down</option>
						</select>
					</label>

					<label>
						<span>Loop</span>
						<input
							name="loop"
							type="number"
							min="-1"
							step="1"
							placeholder="-1"
						/>
					</label>
				</details>

				<details open>
					<summary>Speed</summary>

					<label>
						<span>Scrollamount</span>
						<input
							data-setting-control="range"
							name="scrollamountRange"
							type="range"
							min="0"
							max="30"
							step="1"
							value="6"
						/>
						<input
							data-setting-control="number"
							name="scrollamount"
							type="number"
							min="0"
							max="30"
							step="1"
							value="6"
						/>
					</label>

					<label>
						<span>Scrolldelay</span>
						<input
							data-setting-control="range"
							name="scrolldelayRange"
							type="range"
							min="0"
							max="500"
							step="5"
							value="85"
						/>
						<input
							data-setting-control="number"
							name="scrolldelay"
							type="number"
							min="0"
							max="500"
							step="5"
							value="85"
						/>
					</label>

					<label class="checkbox-control">
						<input name="truespeed" type="checkbox" />
						<span>truespeed</span>
					</label>
				</details>

				<details>
					<summary>Box</summary>

					<label>
						<span>Width</span>
						<input name="width" type="text" value="100%" />
					</label>

					<label>
						<span>Height</span>
						<input name="height" type="text" value="" placeholder="auto" />
					</label>

					<label>
						<span>Bgcolor</span>
						<input
							data-color-hex
							name="bgcolor"
							inputmode="text"
							maxlength="6"
							pattern="[0-9a-fA-F]{3}|[0-9a-fA-F]{6}"
							spellcheck="false"
							type="text"
							value=""
							placeholder="transparent"
						/>
						<input data-color-picker="bgcolor" type="color" value="#000000" />
					</label>

					<label>
						<span>Hspace</span>
						<input name="hspace" type="text" value="" placeholder="0" />
					</label>

					<label>
						<span>Vspace</span>
						<input name="vspace" type="text" value="" placeholder="0" />
					</label>
				</details>

				<details>
					<summary>Style</summary>

					<label>
						<span>Font Size (px)</span>
						<input
							name="fontSize"
							type="number"
							min="8"
							max="96"
							step="1"
							value=""
							placeholder="16"
						/>
					</label>

					<label>
						<span>Color</span>
						<input
							data-color-hex
							name="color"
							inputmode="text"
							maxlength="6"
							pattern="[0-9a-fA-F]{3}|[0-9a-fA-F]{6}"
							spellcheck="false"
							type="text"
							value=""
							placeholder="currentColor"
						/>
						<input data-color-picker="color" type="color" value="#000000" />
					</label>
				</details>

				<details>
					<summary>Content</summary>

					<label>
						<span>Marquee Content</span>
						<textarea name="content" rows="4"></textarea>
					</label>
				</details>
			</form>
		</section>
	</main>

	<script slot="scripts" type="module" src={demoScriptUrl}></script>
</BaseLayout>
